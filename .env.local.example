# 複製做 .env.local 並填入真值（唔好將 .env.local 提交到 git）
NEXT_PUBLIC_SITE_URL=https://hkbookkeep.harbix.app
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase → Authentication → URL：Site URL 同上；Redirect URLs 加
# https://hkbookkeep.harbix.app/auth/callback（本機再加 http://localhost:3000/auth/callback）
# 認證電郵（驗證／重設密碼）用 Dashboard 自訂 SMTP（例如 Resend）

# 伺服器專用（唔好提交到 git）
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...

# 聯絡表單經 Unosend（https://api.unosend.co/emails）
UNOSEND_API_KEY=un_...
# CONTACT_FROM_EMAIL="HKBookkeep <hkbookkeep@harbix.app>"
CONTACT_TO_EMAIL=hkbookkeep@harbix.app

# 本機開發可設 1 以跳過訂閱檢查（切勿用於正式環境）
# NEXT_PUBLIC_DEV_FULL_ACCESS=1
