# 複製做 .env.local 並填入真值（唔好將 .env.local 提交到 git）
# 本機 localhost 無法用網域判斷市場時，設 hk | tw | sg（預設 hk）
# NEXT_PUBLIC_MARKET=hk
NEXT_PUBLIC_SITE_URL=https://hkbookkeep.harbix.app
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase → Authentication：Site URL 可用主站（例如 hkbookkeep）；Redirect URLs 須包含各網域：
# http://localhost:3000/auth/callback
# http://localhost:3000/auth/reset-password
# https://hkbookkeep.harbix.app/auth/callback
# https://hkbookkeep.harbix.app/auth/reset-password
# https://twbookkeep.harbix.app/auth/callback
# https://twbookkeep.harbix.app/auth/reset-password
# https://sgbookkeep.harbix.app/auth/callback
# https://sgbookkeep.harbix.app/auth/reset-password
# （可選）一條通配避免 OAuth redirectTo 被判唔匹配而掉去 Site URL 根路徑：
# https://*bookkeep.harbix.app/auth/callback
# https://*bookkeep.harbix.app/auth/reset-password
# 認證電郵（驗證／重設密碼）用 Dashboard 自訂 SMTP（例如 Resend）

# 伺服器專用（唔好提交到 git）
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...
# 台灣／星加坡須另有 TWD、SGD 嘅 Price（可同一個 Stripe Product 下掛多個 Price）
STRIPE_PRICE_MONTHLY_TW=price_...
STRIPE_PRICE_YEARLY_TW=price_...
STRIPE_PRICE_MONTHLY_SG=price_...
STRIPE_PRICE_YEARLY_SG=price_...

# 聯絡表單：優先用 Resend（https://resend.com）；冇設則用 Unosend
RESEND_API_KEY=re_...
# UNOSEND_API_KEY=un_...
# CONTACT_FROM_EMAIL="HKBookkeep <bookkeep@harbix.app>"
CONTACT_TO_EMAIL=bookkeep@harbix.app

# 本機開發可設 1 以跳過訂閱檢查（切勿用於正式環境）
# NEXT_PUBLIC_DEV_FULL_ACCESS=1
